{
  "name": "house-of-tide",
  "version": "1.0.0",
  "description": "A narrative merchant dynasty game",
  "main": "house-of-tide.html",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "dev": "npx http-server -p 8080 -c-1",
    "dev:webpack": "webpack serve --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "analyze": "webpack --config webpack.prod.js --profile --json > stats.json && webpack-bundle-analyzer stats.json",
    "minify": "for f in hot-*.js; do npx terser \"$f\" -o \"$f\" -c 2>/dev/null || true; done && npx cleancss -o hot-game.css hot-game.css 2>/dev/null || true",
    "minify:check": "echo 'JS:' && wc -c hot-*.js | tail -1 && echo 'CSS:' && wc -c hot-game.css"
  },
  "keywords": [
    "game",
    "narrative",
    "merchant",
    "dynasty"
  ],
  "author": "House of Tide Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "optionalDependencies": {
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.2",
    "webpack-bundle-analyzer": "^4.9.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
